                simple-audio-card,widgets = "Microphone\0Microphone Jack\0Headphone\0Headphone Jack\0Line\0Line In Jack";
                simple-audio-card,mclk-fs = <0x100>;

                simple-audio-card,codec {
                        sound-dai = <0x7b>;
                        phandle = <0x7a>;
                };

                simple-audio-card,cpu {
                        sound-dai = <0x7c>;
                };
        };

        sound-spdif {
                compatible = "fsl,imx-audio-spdif";
                model = "imx-spdif";
                spdif-controller = <0x7d>;
                spdif-out;
                spdif-in;
                status = "disabled";
        };

        sound-micfil {
                compatible = "fsl,imx-audio-card";
                model = "imx-audio-micfil";

                pri-dai-link {
                        link-name = "micfil hifi";
                        format = "i2s";

                        cpu {
                                sound-dai = <0x7e>;
                        };
                };
        };

        chosen {
                stdout-path = "/soc@0/bus@30800000/spba-bus@30800000/serial@30860000";
        };

        backlight {
                compatible = "pwm-backlight";
                pwms = <0x7f 0x00 0xf4240 0x00>;
                brightness-levels = <0x00 0x01 0x02 0x03 0x04 0x05 0x06 0x07 0x08 0x09 0x0a 0x0b 0x0c 0x0d 0x0e 0x0f 0x10 0x11 0x12 0x13 0x14 0x15 0x16 0x17 0x18 0x19 0x1a 0x1b 0x1c 0x1d 0x1e 0x1f 0x20 0x21 0x22 0x23 0x24 0x25 0x26 0x27 0x28 0x29 0x2a 0x2b 0x2c 0x2d 0x2e 0x2f 0x30 0x31 0x32 0x33 0x34 0x35 0x36 0x37 0x38 0x39 0x3a 0x3b 0x3c 0x3d 0x3e 0x3f 0x40 0x41 0x42 0x43 0x44 0x45 0x46 0x47 0x48 0x49 0x4a 0x4b 0x4c 0x4d 0x4e 0x4f 0x50 0x51 0x52 0x53 0x54 0x55 0x56 0x57 0x58 0x59 0x5a 0x5b 0x5c 0x5d 0x5e 0x5f 0x60 0x61 0x62 0x63 0x64>;
                default-brightness-level = <0x50>;
                status = "okay";
                phandle = <0x77>;
        };

        gpio-keys {
                compatible = "gpio-keys";
                status = "okay";
                pinctrl-names = "default";
                pinctrl-0 = <0x80>;

                up {
                        label = "Up";
                        gpios = <0x24 0x12 0x01>;
                        linux,code = <0x67>;
                        wakeup-source;
                };

                down {
                        label = "Down";
                        gpios = <0x24 0x0f 0x01>;
                        linux,code = <0x6c>;
                        wakeup-source;
                };

                home {
                        label = "Home";
                        gpios = <0x24 0x0d 0x01>;
                        linux,code = <0x66>;
                        wakeup-source;
                };

                back {
                        label = "Back";
                        gpios = <0x24 0x06 0x01>;
                        linux,code = <0x9e>;
                        wakeup-source;
                };
        };

        gpio-leds {
                compatible = "gpio-leds";
                pinctrl-names = "default";
                pinctrl-0 = <0x81>;
                status = "okay";

                emmc {
                        label = "eMMC";
                        gpios = <0x24 0x11 0x00>;
                        linux,default-trigger = "mmc2";
                };
        };

        pcie0-refclk {
                compatible = "fixed-clock";
                #clock-cells = <0x00>;
                clock-frequency = <0x5f5e100>;
                phandle = <0x6d>;
        };

        regulator-usdhc2 {
                compatible = "regulator-fixed";
                pinctrl-names = "default";
                pinctrl-0 = <0x82>;
                regulator-name = "VSD_3V3";
                regulator-min-microvolt = <0x325aa0>;
                regulator-max-microvolt = <0x325aa0>;
                gpio = <0x2c 0x13 0x00>;
                off-on-delay = <0x4e20>;
                enable-active-high;
                phandle = <0x49>;
        };

        can0_osc {
                compatible = "fixed-clock";
                #clock-cells = <0x00>;
                clock-frequency = <0x1312d00>;
                phandle = <0x26>;
        };
};
