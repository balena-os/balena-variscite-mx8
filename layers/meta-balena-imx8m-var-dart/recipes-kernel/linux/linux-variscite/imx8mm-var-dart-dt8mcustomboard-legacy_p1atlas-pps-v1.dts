/dts-v1/;

/ {
        interrupt-parent = <0x01>;
        #address-cells = <0x02>;
        #size-cells = <0x02>;
        compatible = "variscite,imx8mm-var-dart\0fsl,imx8mm";
        model = "Variscite DART-MX8M-MINI on DT8MCustomBoard 1.x";
        // P1: Added for ptp Added PPS (Pulse Per Second) GPIO support to enable GPS-disciplined PTP
        // timing on the Atlas platform.
        // Note: This disables UART2 to avoid a pin conflict.
        pps-enabled = "feb26-2026-v1 rising edge on GPIO152";


        aliases {
                ethernet0 = "/soc@0/bus@30800000/ethernet@30be0000";
                gpio0 = "/soc@0/bus@30000000/gpio@30200000";
                gpio1 = "/soc@0/bus@30000000/gpio@30210000";
                gpio2 = "/soc@0/bus@30000000/gpio@30220000";
                gpio3 = "/soc@0/bus@30000000/gpio@30230000";
                gpio4 = "/soc@0/bus@30000000/gpio@30240000";
                i2c0 = "/soc@0/bus@30800000/i2c@30a20000";
                i2c1 = "/soc@0/bus@30800000/i2c@30a30000";
                i2c2 = "/soc@0/bus@30800000/i2c@30a40000";
                i2c3 = "/soc@0/bus@30800000/i2c@30a50000";
                mmc0 = "/soc@0/bus@30800000/mmc@30b40000";
                mmc1 = "/soc@0/bus@30800000/mmc@30b50000";
                mmc2 = "/soc@0/bus@30800000/mmc@30b60000";
                sai1 = "/soc@0/bus@30000000/spba-bus@30000000/sai@30010000";
                sai2 = "/soc@0/bus@30000000/spba-bus@30000000/sai@30020000";
                sai3 = "/soc@0/bus@30000000/spba-bus@30000000/sai@30030000";
                sai5 = "/soc@0/bus@30000000/spba-bus@30000000/sai@30050000";
                sai6 = "/soc@0/bus@30000000/spba-bus@30000000/sai@30060000";
                serial0 = "/soc@0/bus@30800000/spba-bus@30800000/serial@30860000";
                serial1 = "/soc@0/bus@30800000/spba-bus@30800000/serial@30890000";
                serial2 = "/soc@0/bus@30800000/spba-bus@30800000/serial@30880000";
                serial3 = "/soc@0/bus@30800000/serial@30a60000";
                spi0 = "/soc@0/bus@30800000/spba-bus@30800000/spi@30820000";
                spi1 = "/soc@0/bus@30800000/spba-bus@30800000/spi@30830000";
                spi2 = "/soc@0/bus@30800000/spba-bus@30800000/spi@30840000";
        };

        // P1: This DTS node configures GPIO5_IO24 as a PPS input using the
        // kernel pps-gpio driver, creating /dev/pps1 to capture GPS 1PPS edges with nanosecond
        // precision for GPS-disciplined PTP/chrony synchronization
        pps {
                pinctrl-names = "default";
                pinctrl-0 = <0x99>;
                compatible = "pps-gpio";
                gpios = <0x22 24 0>;
                status = "okay";
        };

        cpus {
                #address-cells = <0x01>;
                #size-cells = <0x00>;

                idle-states {
                        entry-method = "psci";

                        cpu-pd-wait {
                                compatible = "arm,idle-state";
                                arm,psci-suspend-param = <0x10033>;
                                local-timer-stop;
                                entry-latency-us = <0x3e8>;
                                exit-latency-us = <0x2bc>;
                                min-residency-us = <0xa8c>;
                                phandle = <0x06>;
                        };
                };

                cpu@0 {
                        device_type = "cpu";
                        compatible = "arm,cortex-a53";
                        reg = <0x00>;
                        clock-latency = <0xee6c>;
                        clocks = <0x02 0xd7>;
                        enable-method = "psci";
                        next-level-cache = <0x03>;
                        operating-points-v2 = <0x04>;
                        nvmem-cells = <0x05>;
                        nvmem-cell-names = "speed_grade";
                        cpu-idle-states = <0x06>;
                        #cooling-cells = <0x02>;
                        cpu-supply = <0x07>;
                        phandle = <0x0d>;
                };

                cpu@1 {
                        device_type = "cpu";
                        compatible = "arm,cortex-a53";
                        reg = <0x01>;
                        clock-latency = <0xee6c>;
                        clocks = <0x02 0xd7>;
                        enable-method = "psci";
                        next-level-cache = <0x03>;
                        operating-points-v2 = <0x04>;
                        cpu-idle-states = <0x06>;
                        #cooling-cells = <0x02>;
                        cpu-supply = <0x07>;
                        phandle = <0x0e>;
                };

                cpu@2 {
                        device_type = "cpu";
                        compatible = "arm,cortex-a53";
                        reg = <0x02>;
                        clock-latency = <0xee6c>;
                        clocks = <0x02 0xd7>;
                        enable-method = "psci";
                        next-level-cache = <0x03>;
                        operating-points-v2 = <0x04>;
                        cpu-idle-states = <0x06>;
                        #cooling-cells = <0x02>;
                        cpu-supply = <0x07>;
                        phandle = <0x0f>;
                };

                cpu@3 {
                        device_type = "cpu";
                        compatible = "arm,cortex-a53";
                        reg = <0x03>;
                        clock-latency = <0xee6c>;
                        clocks = <0x02 0xd7>;
                        enable-method = "psci";
                        next-level-cache = <0x03>;
                        operating-points-v2 = <0x04>;
                        cpu-idle-states = <0x06>;
                        #cooling-cells = <0x02>;
                        cpu-supply = <0x07>;
                        phandle = <0x10>;
                };

                l2-cache0 {
                        compatible = "cache";
                        phandle = <0x03>;
                };
        };

        opp-table {
                compatible = "operating-points-v2";
                opp-shared;
                phandle = <0x04>;

                opp-1200000000 {
                        opp-hz = <0x00 0x47868c00>;
                        opp-microvolt = <0xcf850>;
                        opp-supported-hw = <0x0e 0x07>;
                        clock-latency-ns = <0x249f0>;
                        opp-suspend;
                };

                opp-1600000000 {
                        opp-hz = <0x00 0x5f5e1000>;
                        opp-microvolt = <0xe7ef0>;
                        opp-supported-hw = <0x0c 0x07>;
                        clock-latency-ns = <0x249f0>;
                        opp-suspend;
                };

                opp-1800000000 {
                        opp-hz = <0x00 0x6b49d200>;
                        opp-microvolt = <0xf4240>;
                        opp-supported-hw = <0x08 0x03>;
                        clock-latency-ns = <0x249f0>;
                        opp-suspend;
                };
        };

        reserved-memory {
                #address-cells = <0x02>;
                #size-cells = <0x02>;
                ranges;
        };

        clock-osc-32k {
                compatible = "fixed-clock";
                #clock-cells = <0x00>;
                clock-frequency = <0x8000>;
                clock-output-names = "osc_32k";
                phandle = <0x19>;
        };

        clock-osc-24m {
                compatible = "fixed-clock";
                #clock-cells = <0x00>;
                clock-frequency = <0x16e3600>;
                clock-output-names = "osc_24m";
                phandle = <0x1a>;
        };

        clock-ext1 {
                compatible = "fixed-clock";
                #clock-cells = <0x00>;
                clock-frequency = <0x7ed6b40>;
                clock-output-names = "clk_ext1";
                phandle = <0x1b>;
        };

        clock-ext2 {
                compatible = "fixed-clock";
                #clock-cells = <0x00>;
                clock-frequency = <0x7ed6b40>;
                clock-output-names = "clk_ext2";
                phandle = <0x1c>;
        };

        clock-ext3 {
                compatible = "fixed-clock";
                #clock-cells = <0x00>;
                clock-frequency = <0x7ed6b40>;
                clock-output-names = "clk_ext3";
                phandle = <0x1d>;
        };

        clock-ext4 {
                compatible = "fixed-clock";
                #clock-cells = <0x00>;
                clock-frequency = <0x7ed6b40>;
                clock-output-names = "clk_ext4";
                phandle = <0x1e>;
        };

        psci {
                compatible = "arm,psci-1.0";
                method = "smc";
        };

        pmu {
                compatible = "arm,cortex-a53-pmu";
                interrupts = <0x01 0x07 0xf04>;
        };

        power-domains {
                compatible = "simple-bus";

                hsiomix-pd {
                        compatible = "fsl,imx8m-pm-domain";
                        #power-domain-cells = <0x00>;
                        domain-index = <0x00>;
                        domain-name = "hsiomix";
                        clocks = <0x02 0xc0>;
                        phandle = <0x08>;
                };

                pcie-pd {
                        compatible = "fsl,imx8m-pm-domain";
                        #power-domain-cells = <0x00>;
                        domain-index = <0x01>;
                        domain-name = "pcie";
                        parent-domains = <0x08>;
                        clocks = <0x02 0xa9>;
                        phandle = <0x6a>;
                };

                usbotg1-pd {
                        compatible = "fsl,imx8m-pm-domain";
                        #power-domain-cells = <0x00>;
                        domain-index = <0x02>;
                        domain-name = "usb_otg1";
                        parent-domains = <0x08>;
                        phandle = <0x64>;
                };

                usbotg2-pd {
                        compatible = "fsl,imx8m-pm-domain";
                        #power-domain-cells = <0x00>;
                        domain-index = <0x03>;
                        domain-name = "usb_otg2";
                        parent-domains = <0x08>;
                        phandle = <0x68>;
                };

                gpumix-pd {
                        compatible = "fsl,imx8m-pm-domain";
                        #power-domain-cells = <0x00>;
                        domain-index = <0x04>;
                        domain-name = "gpumix";
                        clocks = <0x02 0xc8 0x02 0x5a 0x02 0xd9 0x02 0xc1>;
                        phandle = <0x76>;
                };

                vpumix-pd {
                        compatible = "fsl,imx8m-pm-domain";
                        #power-domain-cells = <0x00>;
                        domain-index = <0x05>;
                        domain-name = "vpumix";
                        clocks = <0x02 0xd2>;
                        phandle = <0x09>;
                };

                vpug1-pd {
                        compatible = "fsl,imx8m-pm-domain";
                        #power-domain-cells = <0x00>;
                        domain-index = <0x06>;
                        domain-name = "vpu_g1";
                        parent-domains = <0x09>;
                        clocks = <0x02 0xc7>;
                        phandle = <0x74>;
                };

                vpug2-pd {
                        compatible = "fsl,imx8m-pm-domain";
                        #power-domain-cells = <0x00>;
                        domain-index = <0x07>;
                        domain-name = "vpu_g2";
                        parent-domains = <0x09>;
                        clocks = <0x02 0xca>;
                        phandle = <0x75>;
                };

                vpuh1-pd {
                        compatible = "fsl,imx8m-pm-domain";
                        #power-domain-cells = <0x00>;
                        domain-index = <0x08>;
                        domain-name = "vpu_h1";
                        parent-domains = <0x09>;
                        clocks = <0x02 0xc9>;
                        phandle = <0x73>;
                };

                dispmix-pd {
                        compatible = "fsl,imx8m-pm-domain";
                        #power-domain-cells = <0x00>;
                        domain-index = <0x09>;
                        domain-name = "dispmix";
                        clocks = <0x02 0xcc 0x02 0xcd 0x02 0xce>;
                        phandle = <0x0a>;
                };

                mipi-pd {
                        compatible = "fsl,imx8m-pm-domain";
                        #power-domain-cells = <0x00>;
                        domain-index = <0x0a>;
                        domain-name = "mipi";
                        parent-domains = <0x0a>;
                        phandle = <0x5b>;
                };
        };

        timer {
                compatible = "arm,armv8-timer";
                interrupts = <0x01 0x0d 0xf08 0x01 0x0e 0xf08 0x01 0x0b 0xf08 0x01 0x0a 0xf08>;
                clock-frequency = <0x7a1200>;
                arm,no-tick-in-suspend;
        };

        thermal-zones {

                cpu-thermal {
                        polling-delay-passive = <0xfa>;
                        polling-delay = <0x7d0>;
                        thermal-sensors = <0x0b>;

                        trips {

                                trip0 {
                                        temperature = <0x14c08>;
                                        hysteresis = <0x7d0>;
                                        type = "passive";
                                        phandle = <0x0c>;
                                };

                                trip1 {
                                        temperature = <0x17318>;
                                        hysteresis = <0x7d0>;
                                        type = "critical";
                                };
                        };

                        cooling-maps {

                                map0 {
                                        trip = <0x0c>;
                                        cooling-device = <0x0d 0xffffffff 0xffffffff 0x0e 0xffffffff 0xffffffff 0x0f 0xffffffff 0xffffffff 0x10 0xffffffff 0xffffffff>;
                                };
                        };
                };
        };

        usbphynop1 {
                #phy-cells = <0x00>;
                compatible = "usb-nop-xceiv";
                clocks = <0x02 0x84>;
                assigned-clocks = <0x02 0x84>;
                assigned-clock-parents = <0x02 0x32>;
                clock-names = "main_clk";
                phandle = <0x62>;
        };

        usbphynop2 {
                #phy-cells = <0x00>;
                compatible = "usb-nop-xceiv";
                clocks = <0x02 0x84>;
                assigned-clocks = <0x02 0x84>;
                assigned-clock-parents = <0x02 0x32>;
                clock-names = "main_clk";
                phandle = <0x66>;
        };

        busfreq {
                compatible = "fsl,imx_busfreq";
                clocks = <0x02 0x29 0x02 0x61 0x02 0x62 0x02 0x62 0x02 0xdc 0x02 0xdd 0x02 0x30 0x02 0x32 0x02 0x3f 0x02 0x5b 0x02 0x5d 0x02 0x51 0x02 0x02 0x02 0x38 0x02 0x15>;
                clock-names = "dram_pll\0dram_alt_src\0dram_apb_src\0dram_apb_pre_div\0dram_core\0dram_alt_root\0sys_pll1_40m\0sys_pll1_100m\0sys_pll2_333m\0noc_div\0ahb_div\0main_axi_src\0osc_24m\0sys_pll1_800m\0dram_pll_div";
                interrupts = <0x00 0x4a 0x04 0x00 0x4b 0x04 0x00 0x4c 0x04 0x00 0x4d 0x04>;
                interrupt-name = "irq_busfreq_0\0irq_busfreq_1\0irq_busfreq_2\0irq_busfreq_3";
        };

        soc@0 {
                compatible = "simple-bus";
                #address-cells = <0x01>;
                #size-cells = <0x01>;
                ranges = <0x00 0x00 0x00 0x3e000000>;
                dma-ranges = <0x40000000 0x00 0x40000000 0xc0000000>;
                nvmem-cells = <0x11>;
                nvmem-cell-names = "soc_unique_id";

                caam-sm@100000 {
                        compatible = "fsl,imx6q-caam-sm";
                        reg = <0x100000 0x8000>;
                };

                bus@30000000 {
                        compatible = "fsl,aips-bus\0simple-bus";
                        reg = <0x30000000 0x400000>;
                        #address-cells = <0x01>;
                        #size-cells = <0x01>;
                        ranges = <0x30000000 0x30000000 0x400000>;

                        spba-bus@30000000 {
                                compatible = "fsl,spba-bus\0simple-bus";
                                #address-cells = <0x01>;
                                #size-cells = <0x01>;
                                reg = <0x30000000 0x100000>;
                                ranges;

                                sai@30010000 {
                                        #sound-dai-cells = <0x00>;
                                        compatible = "fsl,imx8mm-sai\0fsl,imx8mq-sai";
                                        reg = <0x30010000 0x10000>;
                                        interrupts = <0x00 0x5f 0x04>;
                                        clocks = <0x02 0xb1 0x02 0x00 0x02 0xb0 0x02 0x00 0x02 0x00>;
                                        clock-names = "bus\0mclk0\0mclk1\0mclk2\0mclk3";
                                        dmas = <0x12 0x00 0x02 0x00 0x12 0x01 0x02 0x00>;
                                        dma-names = "rx\0tx";
                                        fsl,dataline = <0x00 0xff 0xff>;
                                        status = "disabled";
                                };

                                sai@30020000 {
                                        #sound-dai-cells = <0x00>;
                                        compatible = "fsl,imx8mm-sai\0fsl,imx8mq-sai";
                                        reg = <0x30020000 0x10000>;
                                        interrupts = <0x00 0x60 0x04>;
                                        clocks = <0x02 0xb3 0x02 0x00 0x02 0xb2 0x02 0x00 0x02 0x00>;
                                        clock-names = "bus\0mclk0\0mclk1\0mclk2\0mclk3";
                                        dmas = <0x12 0x02 0x02 0x00 0x12 0x03 0x02 0x00>;
                                        dma-names = "rx\0tx";
                                        status = "disabled";
                                };

                                sai@30030000 {
                                        #sound-dai-cells = <0x00>;
                                        compatible = "fsl,imx8mm-sai\0fsl,imx8mq-sai";
                                        reg = <0x30030000 0x10000>;
                                        interrupts = <0x00 0x32 0x04>;
                                        clocks = <0x02 0xb5 0x02 0x00 0x02 0xb4 0x02 0x00 0x02 0x00>;
                                        clock-names = "bus\0mclk0\0mclk1\0mclk2\0mclk3";
                                        dmas = <0x12 0x04 0x02 0x00 0x12 0x05 0x02 0x00>;
                                        dma-names = "rx\0tx";
                                        status = "okay";
                                        pinctrl-names = "default";
                                        pinctrl-0 = <0x13>;
                                        assigned-clocks = <0x02 0x6e>;
                                        assigned-clock-parents = <0x02 0x26>;
                                        assigned-clock-rates = <0x177000>;
                                        phandle = <0x7c>;
                                };

                                sai@30050000 {
                                        #sound-dai-cells = <0x00>;
                                        compatible = "fsl,imx8mm-sai\0fsl,imx8mq-sai";
                                        reg = <0x30050000 0x10000>;
                                        interrupts = <0x00 0x5a 0x04>;
                                        clocks = <0x02 0xb9 0x02 0x00 0x02 0xb8 0x02 0x00 0x02 0x00>;
                                        clock-names = "bus\0mclk0\0mclk1\0mclk2\0mclk3";
                                        dmas = <0x12 0x08 0x02 0x00 0x12 0x09 0x02 0x00>;
                                        dma-names = "rx\0tx";
                                        fsl,dataline = <0x00 0x0f 0x0f>;
                                        status = "disabled";
                                };

                                sai@30060000 {
                                        #sound-dai-cells = <0x00>;
                                        compatible = "fsl,imx8mm-sai\0fsl,imx8mq-sai";
                                        reg = <0x30060000 0x10000>;
                                        interrupts = <0x00 0x5a 0x04>;
                                        clocks = <0x02 0xbb 0x02 0x00 0x02 0xba 0x02 0x00 0x02 0x00>;
                                        clock-names = "bus\0mclk0\0mclk1\0mclk2\0mclk3";
                                        dmas = <0x12 0x0a 0x02 0x00 0x12 0x0b 0x02 0x00>;
                                        dma-names = "rx\0tx";
                                        status = "disabled";
                                };

                                audio-controller@30080000 {
                                        compatible = "fsl,imx8mm-micfil";
                                        reg = <0x30080000 0x10000>;
                                        interrupts = <0x00 0x6d 0x04 0x00 0x6e 0x04 0x00 0x2c 0x04 0x00 0x2d 0x04>;
                                        clocks = <0x02 0xd8 0x02 0xcb 0x02 0x26 0x02 0x27 0x02 0x06>;
                                        clock-names = "ipg_clk\0ipg_clk_app\0pll8k\0pll11k\0clkext3";
                                        dmas = <0x12 0x18 0x19 0x80000000>;
                                        dma-names = "rx";
                                        status = "disabled";
                                        #sound-dai-cells = <0x00>;
                                        pinctrl-names = "default";
                                        pinctrl-0 = <0x14>;
                                        assigned-clocks = <0x02 0x9c>;
                                        assigned-clock-parents = <0x02 0x26>;
                                        assigned-clock-rates = <0xbb80000>;
                                        phandle = <0x7e>;
                                };

                                spdif@30090000 {
                                        compatible = "fsl,imx35-spdif";
                                        reg = <0x30090000 0x10000>;
                                        interrupts = <0x00 0x06 0x04>;
                                        clocks = <0x02 0x5e 0x02 0x02 0x02 0x72 0x02 0x00 0x02 0x00 0x02 0x00 0x02 0x5e 0x02 0x00 0x02 0x00 0x02 0x00 0x02 0x26 0x02 0x27>;
                                        clock-names = "core\0rxtx0\0rxtx1\0rxtx2\0rxtx3\0rxtx4\0rxtx5\0rxtx6\0rxtx7\0spba\0pll8k\0pll11k";
                                        dmas = <0x12 0x1c 0x12 0x00 0x12 0x1d 0x12 0x00>;
                                        dma-names = "rx\0tx";
                                        status = "disabled";
                                        pinctrl-names = "default";
                                        pinctrl-0 = <0x15>;
                                        assigned-clocks = <0x02 0x72>;
                                        assigned-clock-parents = <0x02 0x26>;
                                        assigned-clock-rates = <0x1770000>;
                                        phandle = <0x7d>;
                                };
                        };

                        gpio@30200000 {
                                compatible = "fsl,imx8mm-gpio\0fsl,imx35-gpio";
                                reg = <0x30200000 0x10000>;
                                interrupts = <0x00 0x40 0x04 0x00 0x41 0x04>;
                                clocks = <0x02 0xdf>;
                                gpio-controller;
                                #gpio-cells = <0x02>;
                                interrupt-controller;
                                #interrupt-cells = <0x02>;
                                gpio-ranges = <0x16 0x00 0x0a 0x1e>;
                                phandle = <0x23>;
                        };

                        gpio@30210000 {
                                compatible = "fsl,imx8mm-gpio\0fsl,imx35-gpio";
                                reg = <0x30210000 0x10000>;
                                interrupts = <0x00 0x42 0x04 0x00 0x43 0x04>;
                                clocks = <0x02 0xe0>;
                                gpio-controller;
                                #gpio-cells = <0x02>;
                                interrupt-controller;
                                #interrupt-cells = <0x02>;
                                gpio-ranges = <0x16 0x00 0x28 0x15>;
                                phandle = <0x2c>;
                        };

                        gpio@30220000 {
                                compatible = "fsl,imx8mm-gpio\0fsl,imx35-gpio";
                                reg = <0x30220000 0x10000>;
                                interrupts = <0x00 0x44 0x04 0x00 0x45 0x04>;
                                clocks = <0x02 0xe1>;
                                gpio-controller;
                                #gpio-cells = <0x02>;
                                interrupt-controller;
                                #interrupt-cells = <0x02>;
                                gpio-ranges = <0x16 0x00 0x3d 0x1a>;
                        };

                        gpio@30230000 {
                                compatible = "fsl,imx8mm-gpio\0fsl,imx35-gpio";
                                reg = <0x30230000 0x10000>;
                                interrupts = <0x00 0x46 0x04 0x00 0x47 0x04>;
                                clocks = <0x02 0xe2>;
                                gpio-controller;
                                #gpio-cells = <0x02>;
                                interrupt-controller;
                                #interrupt-cells = <0x02>;
                                gpio-ranges = <0x16 0x00 0x57 0x20>;
                                phandle = <0x24>;
                        };

                        gpio@30240000 {
                                compatible = "fsl,imx8mm-gpio\0fsl,imx35-gpio";
                                reg = <0x30240000 0x10000>;
                                interrupts = <0x00 0x48 0x04 0x00 0x49 0x04>;
                                clocks = <0x02 0xe3>;
                                gpio-controller;
                                #gpio-cells = <0x02>;
                                interrupt-controller;
                                #interrupt-cells = <0x02>;
                                gpio-ranges = <0x16 0x00 0x77 0x1e>;
                                phandle = <0x22>;
                        };

                        tmu@30260000 {
                                compatible = "fsl,imx8mm-tmu";
                                reg = <0x30260000 0x10000>;
                                clocks = <0x02 0xd1>;
